      },
      "detectable_error_types": [
        {
          "error_type": "POLICY_CALCULATION_ERROR",
          "condition": "policy_expected_reward_amount != expected_rewards.expected_reward_amount",
          "description": "은행 시스템의 expected_rewards 자체가 상품설정 기준과 다르게 계산된 경우"
        },
        {
          "error_type": "PAYMENT_EXECUTION_ERROR",
          "condition": "expected_rewards.expected_reward_amount > reward_ledger.paid_reward_amount",
          "description": "은행 시스템의 예상 캐시백은 존재하지만 실제 지급 원장에서 누락 또는 과소 지급된 경우"
        },
        {
          "error_type": "EXPECTED_REWARD_ROW_MISSING",
          "condition": "policy_expected_reward_amount > 0 AND expected_rewards.reward_id IS NULL",
          "description": "상품설정 기준으로 캐시백 대상인데 expected_rewards 행 자체가 없는 경우"
        },
        {
          "error_type": "REWARD_LEDGER_ROW_MISSING",
          "condition": "expected_rewards.expected_reward_amount > 0 AND reward_ledger.ledger_id IS NULL",
          "description": "예상 캐시백은 존재하지만 지급 원장 행이 없는 경우"
        }
      ]
    },
